{
  "name": "vert",
  "version": "1.0.0",
  "description": "VERT: Phim khong gioi han",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:android": "cap sync android && cd android && gradlew assembleDebug"
  },
  "build": {
    "appId": "com.vert.app",
    "productName": "Vert",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
